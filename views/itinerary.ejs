<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= itinerary.title %> - Your Award-Winning Plan 🌴</title>
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <a href="#itinerary-content" class="skip-link">Skip to itinerary content</a>

    <header>
        <nav class="header-nav" aria-label="Itinerary navigation">
            <a href="chat" class="nav-btn">Back to Chat</a>
            <a href="reset" class="nav-btn">New Trip</a>
        </nav>
        <h1><%= itinerary.title %> 🌴</h1>
        <p><%= itinerary.description %></p>
    </header>

    <main class="itinerary-container" id="itinerary-content">
        <div class="days-wrapper">
            <% itinerary.days.forEach(day => { %>
                <article class="day-card" aria-labelledby="day-<%= day.day %>-title">
                    <h2 id="day-<%= day.day %>-title">Day <%= day.day %> ☀️</h2>
                    <ul class="activities-list">
                        <% day.activities.forEach(activity => { %>
                            <li>
                                <time class="time" datetime="<%= activity.time %>"><%= activity.time %></time>
                                <div class="activity-details">
                                    <strong><%= activity.location %></strong>
                                    <p><%= activity.description %></p>
                                </div>
                            </li>
                        <% }) %>
                    </ul>
                </article>
            <% }) %>
        </div>
    </main>

    <footer>
        <p>&copy; 2026 Vibrant Travel Planner Assistant</p>
    </footer>
</body>
</html>
